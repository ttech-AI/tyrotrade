# Copy to `.env.local` and fill in values. `.env.local` is gitignored.

# Mock toggle ‚Äî set to `false` to hit real Dataverse (requires login).
VITE_USE_MOCK=true

# Azure AD app registration (SPA platform, PKCE, redirect URI must match)
VITE_AAD_TENANT_ID=
VITE_AAD_CLIENT_ID=
VITE_AAD_REDIRECT_URI=http://localhost:5173

# Dataverse environment URL (no trailing slash)
VITE_DATAVERSE_URL=https://<env-name>.crm4.dynamics.com

# user_impersonation scope for the env above
VITE_DATAVERSE_SCOPE=https://<env-name>.crm4.dynamics.com/user_impersonation

# Google Gemini API key ‚Äî default for the TYRO AI chatbot. Users can
# override from Settings (localStorage). Leave blank to force the
# Settings onboarding flow on first launch.
VITE_GEMINI_API_KEY=

# Supabase publishable (anon) key ‚Äî used as `apikey` header when calling
# the get-copilot-token Edge Function that exchanges the Direct Line
# secret for a per-session token for the TYRO Chat drawer.
VITE_SUPABASE_ANON_KEY=

# Cloudflare Worker URL ‚Äî AIS vessel position proxy (no trailing slash)
VITE_VESSEL_WORKER_URL=https://noisy-smoke-b37a.pinarkrtnloglu.workers.dev

# Copilot Studio ‚Äî TYRO Chat agent
VITE_COPILOT_CHAT_URL=https://copilotstudio.microsoft.com/environments/Default-9efa3bdf-67ad-47e3-8dfb-d1df79a6d7fa/bots/crfc1_agentokBCAt/webchat?__version__=2
VITE_COPILOT_DIRECT_CONNECT_URL=https://default9efa3bdf67ad47e38dfbd1df79a6d7.fa.environment.api.powerplatform.com/copilotstudio/dataverse-backed/authenticated/bots/crfc1_agentokBCAt/conversations?api-version=2022-03-01-preview
VITE_COPILOT_ENVIRONMENT_ID=Default-9efa3bdf-67ad-47e3-8dfb-d1df79a6d7fa
VITE_COPILOT_BOT_SCHEMA=crfc1_agentokBCAt
